{
  "name": "hermes-curator",
  "version": "0.1.0",
  "private": true,
  "description": "Autonomous system to maintain and improve Hermes AI Skills",
  "license": "MIT",
  "author": "LivingColor",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
