    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vitest": "^2.1.8"
  },
  "pnpm": {
    "overrides": {
      "@hermes/core": "file:../hermes-skills/packages/core",
      "@hermes/runner": "file:../hermes-skills/packages/runner"
